# Copy this file to .env and fill in your paths.
# .env is gitignored — never commit it.

# Absolute path to your Sims 4 Mods folder.
MODS_DIR=

# Absolute path to the Sims 4 Gameplay scripts folder.
# Used by decompile_ea.sh to extract EA source for IDE type support.
# Run decompile_ea.sh once after setup, and again after each game patch.
GAME_DIR=
