# Copy to npc_ai_mod/.env (this directory) and fill in paths.
# .env is gitignored — never commit it.

# Absolute path to your Sims 4 Mods folder (used by scripts/build.py --deploy).
MODS_DIR=

# Absolute path to the Sims 4 Gameplay scripts folder (contains core.zip, simulation.zip).
# Used by ../decompile_ea.sh from the repository root. Re-run after game patches.
GAME_DIR=
