# Optional — copy to ai_service/.env (next to pyproject.toml).
# Env vars override these; see BridgeSettings in ai_service/settings.py.

NPC_AI_BRIDGE_HOST=127.0.0.1
NPC_AI_BRIDGE_PORT=8765
NPC_AI_BRIDGE_RELOAD=0

# Omit or leave empty to disable WebSocket auto-ping (required for game's persistent /v1/tick client).
# NPC_AI_BRIDGE_WS_PING_INTERVAL=
# NPC_AI_BRIDGE_WS_PING_TIMEOUT=
